	quests: [
		{
			title: "Поиск пути"
			icon: "minecraft:filled_map"
			x: -3.75d
			y: -5.25d
			description: ["Используйте Journey Map для ориентации! Нажмите «M», чтобы открыть карту. Можно ставить маркеры для обозначения интересных мест, а маркеры смерти добавляются автоматически. Получив карту из квестов жителей, вы добавите путевую точку на Journey Map для удобной навигации."]
			dependencies: ["6A377E0BD0B45BC5"]
			size: 1.5d
			id: "2E56DF35467BE295"
			tasks: [{
				id: "3AF5CCBA45F6DC78"
				type: "checkmark"
				title: "Прочитать"
			}]
			rewards: [
				{
					id: "55079C6539007C92"
