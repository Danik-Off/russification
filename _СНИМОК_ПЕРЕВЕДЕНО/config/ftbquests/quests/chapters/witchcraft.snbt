	quests: [
		{
			title: "Добро пожаловать в Hexerei"
			icon: {
				id: "hexerei:book_of_shadows"
				Count: 1b
				tag: { }
			}
			x: 0.0d
			y: 0.0d
			description: ["Добро пожаловать в Hexerei! В этой цепочке квестов вы узнаете всё необходимое о ведьмовстве."]
			size: 2.0d
			id: "758B99AACB978297"
			tasks: [{
				id: "27A8151F5396B022"
